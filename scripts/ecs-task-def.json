{
    "family": "rag-fds-backend-task",
    "containerDefinitions": [
        {
            "name": "api-backend",
            "image": "<TU_ACCOUNT_ID>.dkr.ecr.<TU_REGION>.amazonaws.com/rag-fds-backend:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp",
                    "name": "api-backend-8000-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "AWS_SECRET_ACCESS_KEY",
                    "value": "tu_secret_key_aqui"
                },
                {
                    "name": "OLLAMA_EMBEDDINGS_MODEL",
                    "value": "tu_modelo_aqui"
                },
                {
                    "name": "S3_BUCKET_NAME",
                    "value": "tu_bucket_aqui"
                },
                {
                    "name": "AZURE_OPENAI_ENDPOINT",
                    "value": "tu_end_point_aqui"
                },
                {
                    "name": "EMBEDDINGS_PROVIDER",
                    "value": "azure"
                },
                {
                    "name": "S3_PREFIX_GOLD",
                    "value": "gold/"
                },
                {
                    "name": "AWS_SESSION_TOKEN",
                    "value": "tu_token_key_aqui"
                },
                {
                    "name": "S3_PREFIX_QUARANTINE",
                    "value": "Quarantine/"
                },
                {
                    "name": "CHROMA_SERVER_PORT",
                    "value": "puerto_del_chroma"
                },
                {
                    "name": "S3_PREFIX_DOCS",
                    "value": "bronze/docs/"
                },
                {
                    "name": "AWS_ACCESS_KEY_ID",
                    "value": "tu_access_key_aqui"
                },
                {
                    "name": "AZURE_OPENAI_API_KEY",
                    "value": "tu_api_key_aqui"
                },
                {
                    "name": "OLLAMA_BASE_URL",
                    "value": "tu_end_point_aqui"
                },
                {
                    "name": "S3_PREFIX_BRONCE",
                    "value": "bronze/processed/"
                },
                {
                    "name": "AZURE_OPENAI_API_VERSION",
                    "value": "tu_version_aqui"
                },
                {
                    "name": "S3_PREFIX_SILVER",
                    "value": "silver/"
                },
                {
                    "name": "AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT",
                    "value": "tu_modelo_aqui"
                },
                {
                    "name": "GOOGLE_API_KEY",
                    "value": "tu_api_key_aqui"
                },
                {
                    "name": "CHROMA_SERVER_HOST",
                    "value": "IP_del_servidor"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/rag-fds-backend-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "taskRoleArn": "arn:aws:iam::<TU_ACCOUNT_ID>:role/LabRole",
    "executionRoleArn": "arn:aws:iam::<TU_ACCOUNT_ID>:role/LabRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "4096",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "enableFaultInjection": false
}